<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Factura / Recibo de Pago</title>
  <style>
    :root {
      --primary-color: #1d9e11;
      --accent-color: #0369a1;
      --text-color: #333333;
      --border-color: #e2e8f0;
    }
    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      color: var(--text-color);
      margin: 0;
      padding: 0;
      font-size: 13px;
    }
    .page-container {
      width: 100%;
      max-width: 800px;
      margin: 0 auto;
      padding: 16px;
      box-sizing: border-box;
      page-break-after: always;
    }
    .page-container:last-child { page-break-after: auto; }

    /* ── Header ── */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 2px solid var(--primary-color);
      padding-bottom: 12px;
      margin-bottom: 14px;
    }
    .header h1 { color: var(--primary-color); margin: 0; font-size: 22px; }
    .header-logo { max-height: 50px; margin-bottom: 4px; }
    .header p { margin: 3px 0 0 0; color: #666; font-size: 12px; }

    /* ── Info section ── */
    .info-section {
      display: flex;
      justify-content: space-between;
      margin-bottom: 14px;
      gap: 12px;
    }
    .info-box {
      width: 48%;
      background-color: #f8fafc;
      padding: 10px 12px;
      border-radius: 6px;
      border: 1px solid var(--border-color);
      box-sizing: border-box;
    }
    .info-box h3 {
      margin: 0 0 6px 0;
      color: var(--primary-color);
      font-size: 13px;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 4px;
    }
    .info-box p { margin: 4px 0; font-size: 12px; }

    /* ── Two-column body ── */
    .body-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
    }
    .body-left { flex: 1 1 0; min-width: 0; }
    .body-right { flex: 0 0 220px; max-width: 220px; }

    /* ── Details table ── */
    .details-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 12px;
    }
    .details-table th, .details-table td {
      padding: 8px 10px;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
      font-size: 12px;
    }
    .details-table th {
      background-color: var(--primary-color);
      color: white;
      font-weight: 600;
    }
    /* Section sub-headers */
    .section-header td {
      background-color: #f0fdf4;
      color: var(--primary-color);
      font-weight: 700;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 5px 10px;
    }
    .section-header-charges td {
      background-color: #eff6ff;
      color: var(--accent-color);
      font-weight: 700;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 5px 10px;
    }
    .charge-row td {
      background-color: #fafcff;
      color: #1e40af;
    }
    .subtotal-row td {
      font-weight: 600;
      border-top: 2px solid var(--border-color);
      background-color: #f8fafc;
    }

    /* ── Totals ── */
    .total-section {
      display: flex;
      align-items: center;
      font-size: 15px;
      gap: 16px;
    }
    .total-amount {
      font-size: 20px;
      font-weight: bold;
      color: var(--primary-color);
    }

    /* ── Receipt image ── */
    .receipt-section { text-align: center; }
    .receipt-section h3 {
      color: var(--primary-color);
      font-size: 13px;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 4px;
      margin: 0 0 8px 0;
    }
    .receipt-image {
      width: 100%;
      max-height: 300px;
      object-fit: contain;
      border: 1px solid var(--border-color);
      border-radius: 4px;
      padding: 4px;
      box-sizing: border-box;
    }

    /* ── Footer ── */
    .footer {
      margin-top: 16px;
      text-align: center;
      font-size: 11px;
      color: #888;
      border-top: 1px solid var(--border-color);
      padding-top: 10px;
    }
  </style>
</head>
<body>
  {{#each invoices}}
  <div class="page-container">

    <!-- Header -->
    <div class="header">
      <div>
        {{#if ../logoBase64}}
        <img src="{{../logoBase64}}" alt="Logo SIRCA" class="header-logo">
        {{else}}
        <h1>SIRCA Plan de Salud</h1>
        {{/if}}
      </div>
      <div style="text-align: center;">
        <h3>COMPROBANTE DE PAGO</h3>
      </div>
      <div style="text-align: right;">
        <p>Día: <strong>{{ today }}</strong></p>
        <p>Contrato: <strong>{{ contractCode }}</strong></p>
      </div>
    </div>

    <!-- Info boxes -->
    <div class="info-section">
      <div class="info-box">
        <h3>Información del Pago</h3>
        <p><strong>Mes de Pago:</strong> {{ billingMonth }}</p>
        <p><strong>Titular:</strong> {{ personName }}</p>
        <p><strong>Documento:</strong> {{ identityCard }}</p>
        {{#if referenceNumber}}
        <p><strong>Referencia:</strong> {{ referenceNumber }}</p>
        {{/if}}
      </div>
    </div>

    <!-- Two-column: detail table left, receipt right -->
    <div class="body-row">
      <div class="body-left">
        <table class="details-table">
          <thead>
            <tr>
              <th>Descripción</th>
              <th style="text-align:center; width:50px;">Cant.</th>
              <th style="text-align:right; width:100px;">Monto</th>
            </tr>
          </thead>
          <tbody>

            <!-- ── Mensualidad ── -->
            <tr class="section-header">
              <td colspan="3">Mensualidad</td>
            </tr>
            {{#each members}}
            <tr>
              <td>{{ this.name }} &nbsp;—&nbsp; {{ this.plan }}</td>
              <td style="text-align:center;">1</td>
              <td style="text-align:right;">{{ this.amountUsd }}</td>
            </tr>
            {{/each}}

            <!-- ── Cargos adicionales (INCLUSION, COMISION, etc.) ── -->
            {{#if hasAdditionalCharges}}
            <tr class="section-header-charges">
              <td colspan="3">Cargos Adicionales</td>
            </tr>
            {{#each additionalCharges}}
            <tr class="charge-row">
              <td>
                <span style="font-weight:600;">[{{ this.category }}]</span>
                &nbsp;{{ this.description }}
              </td>
              <td style="text-align:center;">{{ this.quantity }}</td>
              <td style="text-align:right;">{{ this.totalLine }}</td>
            </tr>
            {{/each}}
            {{/if}}

            <!-- ── Resumen financiero ── -->
            <tr class="subtotal-row">
              <td>Total Factura (USD)</td>
              <td></td>
              <td style="text-align:right;"><strong>${{ totalAmount }}</strong></td>
            </tr>
            <tr>
              <td>Abono recibido ({{ paymentMethod }})</td>
              <td></td>
              <td style="text-align:right;">${{ amountUsd }}</td>
            </tr>
            {{#if amountBs}}
            <tr>
              <td>Equivalente en Bolívares</td>
              <td></td>
              <td style="text-align:right;">{{ amountBs }} Bs.</td>
            </tr>
            <tr>
              <td>Tasa BCV ({{ date }})</td>
              <td></td>
              <td style="text-align:right;">{{ exchangeRateUsdToBs }} Bs.</td>
            </tr>
            {{/if}}
            <tr>
              <td>Asesor</td>
              <td></td>
              <td style="text-align:right;">{{ advisor }}</td>
            </tr>
            <tr>
              <td>Saldo pendiente (USD)</td>
              <td></td>
              <td style="text-align:right;">{{ amountUnpaid }}</td>
            </tr>

          </tbody>
        </table>

        <div class="total-section">
          <p>Total a pagar (USD):&nbsp;<span class="total-amount">${{ totalAmount }}</span></p>
          <p>Total Pagado (USD):&nbsp;<span class="total-amount">${{ amountUsd }}</span></p>
        </div>
      </div>

      {{#if receiptUrl}}
      <div class="body-right">
        <div class="receipt-section">
          <h3>Comprobante Adjunto</h3>
          <img src="{{receiptUrl}}" alt="Comprobante" class="receipt-image">
        </div>
      </div>
      {{/if}}
    </div>

    <div class="footer">
      <p>Este documento es un comprobante digital de pago</p>
      <p>Salud Integral El Rosario C.A. — Gracias por confiar en nosotros.</p>
    </div>
  </div>
  {{/each}}
</body>
</html>
