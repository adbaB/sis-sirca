<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Relación de Pagos por Asesor</title>
  <style>
    :root {
      --primary-color: #1d9e11;
      --text-color: #333333;
      --border-color: #e2e8f0;
      --alt-bg: #f8fafc;
      --subtotal-bg: #e8f5e9;
    }
    * { box-sizing: border-box; }
    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      color: var(--text-color);
      margin: 0;
      padding: 0;
      font-size: 10px;
    }
    .page-container {
      width: 100%;
      margin: 0 auto;
      padding: 10px;
    }

    /* ── Header ───────────────────────────────────────────── */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 3px solid var(--primary-color);
      padding-bottom: 8px;
      margin-bottom: 15px;
    }
    .header-left {
      display: flex;
      align-items: center;
      gap: 15px;
    }
    .header-logo {
      height: 40px;
      width: auto;
      object-fit: contain;
    }
    .header h1 {
      color: var(--primary-color);
      margin: 0;
      font-size: 16px;
      font-weight: 700;
    }
    .header-subtitle {
      color: #666;
      font-size: 10px;
      margin: 2px 0 0 0;
    }
    .header-right {
      text-align: right;
      font-size: 9px;
      color: #666;
    }
    .header-right p { margin: 2px 0; }

    /* ── Title ────────────────────────────────────────────── */
    .report-title {
      text-align: center;
      margin-bottom: 15px;
    }
    .report-title h2 {
      color: var(--primary-color);
      margin: 0 0 4px 0;
      font-size: 14px;
    }
    .report-title p {
      color: #333;
      margin: 0;
      font-size: 10px;
      font-weight: bold;
    }

    /* ── Section Header ───────────────────────────────────── */
    .section-title-bar {
      background-color: var(--primary-color);
      color: white;
      font-size: 10px;
      font-weight: bold;
      padding: 6px 10px;
      margin-top: 15px;
      margin-bottom: 0;
      border-radius: 4px 4px 0 0;
    }

    /* ── Table ────────────────────────────────────────────── */
    .report-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 10px;
    }
    .report-table th,
    .report-table td {
      padding: 5px 6px;
      text-align: center;
      border: 1px solid var(--border-color);
      font-size: 9px;
    }
    .report-table th {
      background-color: #f1f5f9;
      color: #334155;
      font-weight: bold;
    }
    .report-table tbody tr:nth-child(even) td {
      background-color: var(--alt-bg);
    }
    .text-left {
      text-align: left !important;
    }
    .text-right {
      text-align: right !important;
    }
    
    .subtotal-row td {
      background-color: var(--subtotal-bg) !important;
      font-weight: bold;
    }
    
    .section-total-row td {
      font-weight: bold;
      color: var(--primary-color);
      font-size: 10px;
    }

    /* ── Grand Total ──────────────────────────────────────── */
    .grand-total-box {
      margin-top: 25px;
      width: 100%;
      border-collapse: collapse;
    }
    .grand-total-box td {
      padding: 8px 12px;
      font-size: 11px;
      font-weight: bold;
      border: 1px solid var(--primary-color);
    }
    .grand-total-label {
      background-color: var(--primary-color);
      color: white;
      text-align: right;
    }
    .grand-total-value {
      background-color: var(--primary-color);
      color: white;
      text-align: center;
      width: 150px;
    }

    /* ── Footer ───────────────────────────────────────────── */
    .footer {
      margin-top: 30px;
      text-align: center;
      font-size: 8px;
      color: #999;
      border-top: 1px solid var(--border-color);
      padding-top: 8px;
    }
    .footer p { margin: 2px 0; }
  </style>
</head>
<body>
  <div class="page-container">
    <!-- Header -->
    <div class="header">
      <div class="header-left">
        {{#if logo}}
        <img src="{{ logo }}" alt="Logo" class="header-logo" />
        {{/if}}
        <div>
          <h1>SIRCA Plan de Salud</h1>
          <p class="header-subtitle">Salud Integral El Rosario C.A.</p>
        </div>
      </div>
      <div class="header-right">
        <p>Generado: <strong>{{ generatedAt }}</strong></p>
      </div>
    </div>

    <!-- Report title -->
    <div class="report-title">
      <h2>RELACIÓN DE PAGOS POR ASESOR</h2>
      <p>Asesor: {{ advisorName }}</p>
      <p>Mes de Facturación: {{ billingMonthLabel }}</p>
    </div>

    <!-- Sections Loop (Portfolios) -->
    {{#each sections}}
      {{#if payments.length}}
        <div class="section-title-bar">CARTERA: {{ portfolioCode }}</div>
        <table class="report-table">
          <thead>
            <tr>
              <th style="width: 10%;">CONTRATO</th>
              <th class="text-left" style="width: 20%;">TITULAR</th>
              <th style="width: 10%;">FECHA PAGO</th>
              <th style="width: 12%;">REFERENCIA</th>
              <th style="width: 12%;">MÉTODO</th>
              <th style="width: 10%;">ESTADO FACT.</th>
              <th class="text-right" style="width: 8%;">EXCEDENTE ($)</th>
              <th class="text-right" style="width: 9%;">MONTO BS.</th>
              <th class="text-right" style="width: 9%;">MONTO USD ($)</th>
            </tr>
          </thead>
          <tbody>
            {{#each payments}}
              <tr>
                <td>{{ contractCode }}</td>
                <td class="text-left">{{ titularName }}<br/><small style="color: #666;">{{ titularCard }}</small></td>
                <td>{{ paymentDateES }}</td>
                <td>{{ referenceNumber }}</td>
                <td>{{ paymentMethod }}</td>
                <td>{{ invoiceStatusLabel }}</td>
                <td class="text-right">${{ surplusAmountFormatted }}</td>
                <td class="text-right">Bs. {{ paymentAmountBsFormatted }}</td>
                <td class="text-right">${{ paymentAmountFormatted }}</td>
              </tr>
            {{/each}}
            
            <!-- Subtotals Row -->
            <tr class="subtotal-row">
              <td class="text-left" colspan="6">Subtotales</td>
              <td class="text-right">${{ subtotalSurplusFormatted }}</td>
              <td class="text-right">Bs. {{ subtotalBsFormatted }}</td>
              <td class="text-right">${{ subtotalUsdFormatted }}</td>
            </tr>
          </tbody>
        </table>
      {{/if}}
    {{/each}}

    <!-- Grand Total Table -->
    <table class="grand-total-box">
      <tr>
        <td class="grand-total-label">MONTO TOTAL EXCEDENTES ($):</td>
        <td class="grand-total-value">${{ grandTotalSurplusFormatted }}</td>
      </tr>
      <tr>
        <td class="grand-total-label">MONTO TOTAL PAGOS BS. (Bs.):</td>
        <td class="grand-total-value">Bs. {{ grandTotalBsFormatted }}</td>
      </tr>
      <tr>
        <td class="grand-total-label">MONTO TOTAL PAGOS USD ($):</td>
        <td class="grand-total-value">${{ grandTotalUsdFormatted }}</td>
      </tr>
    </table>

    <!-- Footer -->
    <div class="footer">
      <p>Este documento es un reporte interno del sistema SIRCA.</p>
      <p>© 2026 Salud Integral El Rosario C.A. Todos los derechos reservados.</p>
    </div>
  </div>
</body>
</html>
