{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "SCREEN_IDENTIFICATION": [
      "SCREEN_INVOICES"
    ],
    "SCREEN_INVOICES": [
      "SCREEN_PAYMENT_METHOD"
    ],
    "SCREEN_PAYMENT_METHOD": [
      "SCREEN_PAYMENT_DETAILS"
    ]
  },
  "screens": [
    {
      "id": "SCREEN_IDENTIFICATION",
      "title": "Paso 1: Identificación",
      "data": {},
      "terminal": false,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "identification_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "¡Hagamos tu pago rápido y seguro! 💳"
              },
              {
                "type": "TextSubheading",
                "text": "Para empezar a buscar tus facturas pendientes, por favor indícame tu documento."
              },
              {
                "type": "Dropdown",
                "label": "Tipo de Documento",
                "name": "doc_type",
                "required": true,
                "data-source": [
                  { "id": "V", "title": "V - Venezolano" },
                  { "id": "E", "title": "E - Extranjero" },
                  { "id": "J", "title": "J - Jurídico" },
                  { "id": "G", "title": "G - Gubernamental" },
                  { "id": "C", "title": "C - Comuna" }
                ]
              },
              {
                "type": "TextInput",
                "label": "Número de documento",
                "name": "doc_number",
                "input-type": "number",
                "required": true
              },
              {
                "type": "Footer",
                "label": "Buscar mis facturas",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "action": "fetch_invoices",
                    "doc_type": "${form.doc_type}",
                    "doc_number": "${form.doc_number}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SCREEN_INVOICES",
      "title": "Tus Facturas",
      "data": {
        "invoices": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "__example__": [
            { "id": "inv1", "title": "Factura Ene", "description": "100.00 USD" }
          ]
        }
      },
      "terminal": false,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "invoices_form",
            "children": [
              {
                "type": "CheckboxGroup",
                "name": "selected_invoices",
                "required": true,
                "label": "¿Cuáles facturas deseas pagar hoy?",
                "data-source": "${data.invoices}"
              },
              {
                "type": "Footer",
                "label": "Continuar con el pago",
                "on-click-action": {
                  "name": "navigate",
                  "next": {
                    "type": "screen",
                    "name": "SCREEN_PAYMENT_METHOD"
                  },
                  "payload": {
                    "selected_invoices": "${form.selected_invoices}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SCREEN_PAYMENT_METHOD",
      "title": "Método de Pago",
      "data": {
        "selected_invoices": {
          "type": "array",
          "items": { "type": "string" },
          "__example__": ["inv1"]
        }
      },
      "terminal": false,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
              "type":"TextHeading",
              "text": "¿Cómo prefieres pagar?"
          },  
          {
            "type": "Form",
            "name": "payment_form",
            "children": [
              {
                "type": "Dropdown",
                "label": "Elige una opción",
                "name": "payment_method",
                "required": true,
                "data-source": [
                  { "id": "transferencia", "title": "Transferencia Bancaria" },
                  { "id": "pago_movil", "title": "Pago Móvil" },
                  { "id": "zelle", "title": "Zelle" }
                ]
              },
              {
                "type": "Footer",
                "label": "Ver datos bancarios",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "action": "fetch_payment_details",
                    "selected_invoices": "${data.selected_invoices}",
                    "payment_method": "${form.payment_method}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SCREEN_PAYMENT_DETAILS",
      "title": "Resumen Final",
      "data": {
        "payment_info": { "type": "string", "__example__": "Datos de transferencia..." },
        "total_amount": { "type": "string", "__example__": "100.00" },
        "selected_invoices": {
          "type": "array",
          "items": { "type": "string" },
          "__example__": ["Factura 001", "Factura 002"]
        },
        "payment_method": { "type": "string", "__example__": "Pago Movil" }
      },
      "terminal": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Monto Total a Pagar"
          },
          {
            "type": "TextBody",
            "text": "${data.total_amount}"
          },
          {
            "type": "TextHeading",
            "text": "Instrucciones de Pago"
          },
          {
            "type": "TextBody",
            "text": "${data.payment_info}"
          },
          {
            "type": "TextBody",
            "text": "⚠️ **¡Último paso!** Al presionar el botón de abajo esta ventana se cerrará. Recuerda enviar la imagen (capture) de tu comprobante directamente en el chat para confirmar tu pago."
          },
          {
            "type": "Footer",
            "label": "Entendido, enviar comprobante",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "selected_invoices": "${data.selected_invoices}",
                "payment_method": "${data.payment_method}",
                "total_amount": "${data.total_amount}"
              }
            }
          }
        ]
      }
    }
  ]
}